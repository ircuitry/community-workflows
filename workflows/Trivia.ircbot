    },
    {
      "id": "regex",
      "type": "logic.regex",
      "x": 572,
      "y": 0,
      "muted": false,
      "streamAsTool": false,
      "title": "split q@@@a",
      "params": {
        "pattern": "^(.*)@@@(.*)$",
        "ci": "false"
      }
    }
