      "toPin": 0
    },
    {
      "from": "gSet",
      "fromPin": 0,
      "to": "gRep",
      "toPin": 0
    },
    {
      "from": "gregex",
      "fromPin": 2,
      "to": "gSet",
      "toPin": 1
    },
    {
      "from": "gregex",
      "fromPin": 3,
      "to": "gRep",
      "toPin": 1
    }
  ]
}
