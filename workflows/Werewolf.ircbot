      "type": "code.run",
      "x": 572,
      "y": 0,
      "muted": false,
      "streamAsTool": false,
      "title": "add player",
      "params": {
        "language": "python",
        "code": "import os\nlst=[x for x in os.environ.get('INPUT','').split(',') if x]\nnick=os.environ.get('NICK','')\nif nick in lst:\n    print(','.join(lst)+'@@@'+nick+' is already in the village ('+str(len(lst))+' players).')\nelse:\n    lst.append(nick)\n    print(','.join(lst)+'@@@🏡 '+nick+' joins the village — '+str(len(lst))+' gathered. !wolf start when ready.')",
        "timeout": "5"
      }
    },
