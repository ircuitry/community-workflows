      "id": "scode",
      "type": "code.run",
      "x": 572,
      "y": 170,
      "muted": false,
      "streamAsTool": false,
      "title": "deal roles",
      "params": {
        "language": "python",
        "code": "import os,random\nlst=[x for x in os.environ.get('INPUT','').split(',') if x]\nif len(lst)<4:\n    print('@@@🐺 Need at least 4 players ('+str(len(lst))+' so far). !wolf join')\n    raise SystemExit\nrandom.shuffle(lst)\nroles=dict()\nroles[lst[0]]='wolf'\nroles[lst[1]]='seer'\nfor n in lst[2:]:\n    roles[n]='villager'\nassign=','.join(n+':'+r for n,r in roles.items())\nv=sum(1 for r in roles.values() if r=='villager')\nprint(assign+'@@@🌙 Night falls over the village of '+str(len(lst))+'. Roles dealt in secret — PM me !wolf myrole. (1 werewolf, 1 seer, '+str(v)+' villagers)')",
        "timeout": "5"
      }
    },
