      "title": "reveal all",
      "params": {
        "language": "python",
        "code": "import os\nd=[x for x in os.environ.get('INPUT','').split(',') if ':' in x]\nif not d:\n    print('No game in progress. !wolf start to deal roles.')\nelse:\n    out=[]\n    for x in d:\n        n,r=x.split(':')\n        tag=dict(wolf='🐺 wolf', seer='🔮 seer', villager='🧑 villager').get(r,r)\n        out.append(n+' = '+tag)\n    print('🔦 Roles revealed — '+' · '.join(out))",
