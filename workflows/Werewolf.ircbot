      "title": "your role",
      "params": {
        "language": "python",
        "code": "import os\nd=dict(x.split(':') for x in os.environ.get('INPUT','').split(',') if ':' in x)\nnick=os.environ.get('NICK','')\nr=d.get(nick,'')\ninfo=dict(wolf='🐺 You are the WEREWOLF. Each night, secretly choose a victim. Blend in by day!', seer='🔮 You are the SEER. Each night you learn whether one player is a wolf.', villager='🧑 You are a VILLAGER. Find the wolf by day and vote to lynch them.')\nif not r:\n    print('You are not in this game, '+nick+'. !wolf join then !wolf start.')\nelse:\n    print(info.get(r,'Your role: '+r))",
        "timeout": "5"
      }
    },
