{
  "format": "ircuitry.workflow.v1",
  "name": "IRCv3 Connection Info",
  "description": "Report what the bot knows about this connection. !network shows the NETWORK name from RPL_ISUPPORT (005), !mynick the current nick, !mychannels the channels it has joined.",
  "author": "ircuitry",
  "category": "Testing",
  "tags": [
    "ircv3",
    "testing",
    "developer",
    "isupport",
    "state"
  ],
  "nodes": [
    {
