      "type": "event.command",
      "x": 0,
      "y": 0,
      "muted": false,
      "streamAsTool": false,
      "title": "!network",
      "params": {
        "prefix": "!",
        "command": "network",
        "contexts": "public, private, pm"
      }
    },
    {
